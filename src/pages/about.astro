---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>About OZ Specialist</h1>
			<p class="subtitle">Leading experts in Opportunity Zone investment consulting and compliance</p>
		</div>
	</section>

	<!-- Company Overview -->
	<section class="oz-services">
		<div class="oz-services-content">
			<div style="max-width: 800px; margin: 0 auto; text-align: center;">
				<h2>Your Trusted Opportunity Zone Investment Partner</h2>
				<p style="font-size: 1.125rem; color: var(--oz-gray-600); margin-bottom: 3rem;">
					OZ Specialist is a premier consulting firm specializing exclusively in Opportunity Zone investments. With over 15 years of combined experience in real estate, tax law, and investment management, we help investors maximize their returns while ensuring full compliance with IRS regulations.
				</p>
			</div>
			
			<div class="oz-authority-stats">
				<div class="oz-stat">
					<span class="oz-stat-number">$2.5B+</span>
					<span class="oz-stat-label">OZ Transactions Analyzed</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">500+</span>
					<span class="oz-stat-label">Properties Evaluated</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">200+</span>
					<span class="oz-stat-label">Clients Served</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">98%</span>
					<span class="oz-stat-label">Client Satisfaction</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Leadership Team -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Our Leadership Team</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<div style="width: 8rem; height: 8rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--oz-white); font-size: 2rem; font-weight: 700;">JS</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 0.5rem;">John Smith</h3>
					<p style="color: var(--oz-gold); font-weight: 600; margin-bottom: 1rem;">Founder & CEO</p>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Former Big 4 tax partner with 20+ years of experience in real estate taxation and Opportunity Zone regulations. Led over $1B in OZ transactions.
					</p>
					<div style="font-size: 0.875rem; color: var(--oz-gray-500);">
						<p><strong>Education:</strong> JD, Harvard Law School</p>
						<p><strong>Certifications:</strong> CPA, CFP</p>
						<p><strong>Experience:</strong> 20+ years</p>
					</div>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<div style="width: 8rem; height: 8rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--oz-white); font-size: 2rem; font-weight: 700;">MJ</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 0.5rem;">Maria Johnson</h3>
					<p style="color: var(--oz-gold); font-weight: 600; margin-bottom: 1rem;">Chief Investment Officer</p>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Former institutional real estate investment manager with expertise in market analysis, due diligence, and portfolio optimization across Opportunity Zones.
					</p>
					<div style="font-size: 0.875rem; color: var(--oz-gray-500);">
						<p><strong>Education:</strong> MBA, Wharton School</p>
						<p><strong>Certifications:</strong> CFA, CCIM</p>
						<p><strong>Experience:</strong> 15+ years</p>
					</div>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<div style="width: 8rem; height: 8rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--oz-white); font-size: 2rem; font-weight: 700;">RB</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 0.5rem;">Robert Brown</h3>
					<p style="color: var(--oz-gold); font-weight: 600; margin-bottom: 1rem;">Head of Compliance</p>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Former IRS attorney specializing in Opportunity Zone regulations and compliance. Ensures all client investments meet IRS requirements and maximize tax benefits.
					</p>
					<div style="font-size: 0.875rem; color: var(--oz-gray-500);">
						<p><strong>Education:</strong> JD, Georgetown Law</p>
						<p><strong>Certifications:</strong> LLM in Taxation</p>
						<p><strong>Experience:</strong> 12+ years</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Our Approach -->
	<section class="oz-tools">
		<div class="oz-tools-content">
			<h2>Our Approach to OZ Investment Consulting</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="width: 3rem; height: 3rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: var(--oz-white); font-size: 1.5rem;">🎯</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Client-Focused Strategy</h3>
					<p>We develop customized investment strategies based on your specific financial goals, risk tolerance, and timeline. Every recommendation is tailored to your unique situation.</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="width: 3rem; height: 3rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: var(--oz-white); font-size: 1.5rem;">📊</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Data-Driven Analysis</h3>
					<p>Our recommendations are based on comprehensive market analysis, financial modeling, and due diligence. We use advanced analytics to identify the best investment opportunities.</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="width: 3rem; height: 3rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: var(--oz-white); font-size: 1.5rem;">⚖️</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Compliance First</h3>
					<p>We ensure every investment meets IRS requirements and maintains your tax benefits. Our compliance-first approach protects your investment and maximizes returns.</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="width: 3rem; height: 3rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; color: var(--oz-white); font-size: 1.5rem;">🤝</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Ongoing Partnership</h3>
					<p>We provide continuous support throughout your investment lifecycle, from initial strategy development to exit planning and tax optimization.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Certifications & Credentials -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Professional Certifications & Credentials</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">CPA</h3>
					<p style="color: var(--oz-gray-600);">Certified Public Accountant</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">CFA</h3>
					<p style="color: var(--oz-gray-600);">Chartered Financial Analyst</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">CCIM</h3>
					<p style="color: var(--oz-gray-600);">Certified Commercial Investment Member</p>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow); text-align: center;">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">CFP</h3>
					<p style="color: var(--oz-gray-600);">Certified Financial Planner</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Client Testimonials -->
	<section class="oz-testimonials">
		<div class="oz-testimonials-content">
			<h2>What Our Clients Say</h2>
			<div class="oz-testimonials-grid">
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">OZ Specialist's expertise in Opportunity Zone regulations saved us from a costly compliance mistake. Their thorough analysis and ongoing support have been invaluable to our investment success.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">JS</div>
						<div class="oz-testimonial-info">
							<h4>John Smith</h4>
							<p>Real Estate Developer, Miami</p>
						</div>
					</div>
				</div>
				
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">The team's market analysis and property evaluation helped us identify a development opportunity that has exceeded our return expectations. Their professional approach and attention to detail are exceptional.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">MJ</div>
						<div class="oz-testimonial-info">
							<h4>Maria Johnson</h4>
							<p>Investment Advisor, Austin</p>
						</div>
					</div>
				</div>
				
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">Working with OZ Specialist has been a game-changer for our investment strategy. Their tax optimization expertise has resulted in significant savings while maintaining strong returns.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">RB</div>
						<div class="oz-testimonial-info">
							<h4>Robert Brown</h4>
							<p>High Net Worth Investor, Denver</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Ready to Work with OZ Specialists?</h2>
			<p>Schedule a consultation with our team of experts to discuss your Opportunity Zone investment goals and explore how we can help you maximize your returns.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Schedule Consultation</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download Our Guide</a>
			</div>
		</div>
	</section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "OZ Specialist",
  "url": "https://opportunityzonespecialist.com",
  "logo": "https://opportunityzonespecialist.com/logo.png",
  "description": "Leading experts in Opportunity Zone investment consulting and compliance",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "US"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+1-555-123-4567",
    "contactType": "customer service",
    "email": "info@opportunityzonespecialist.com"
  },
  "founder": {
    "@type": "Person",
    "name": "John Smith"
  },
  "employee": [
    {
      "@type": "Person",
      "name": "John Smith",
      "jobTitle": "Founder & CEO"
    },
    {
      "@type": "Person",
      "name": "Maria Johnson",
      "jobTitle": "Chief Investment Officer"
    },
    {
      "@type": "Person",
      "name": "Robert Brown",
      "jobTitle": "Head of Compliance"
    }
  ],
  "serviceArea": {
    "@type": "Country",
    "name": "United States"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Opportunity Zone Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Investment Consulting"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Property Analysis"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Tax Optimization"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Fund Formation"
        }
      }
    ]
  }
}
</script>

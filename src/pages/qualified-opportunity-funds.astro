---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>Qualified Opportunity Fund Formation & Management</h1>
			<p class="subtitle">Expert guidance for QOF formation, compliance, and ongoing administration</p>
		</div>
	</section>

	<!-- QOF Overview -->
	<section class="oz-services">
		<div class="oz-services-content">
			<div style="max-width: 800px; margin: 0 auto; text-align: center;">
				<h2>What is a Qualified Opportunity Fund?</h2>
				<p style="font-size: 1.125rem; color: var(--oz-gray-600); margin-bottom: 3rem;">
					A Qualified Opportunity Fund (QOF) is an investment vehicle organized as a corporation or partnership for the purpose of investing in Opportunity Zone property. QOFs provide investors with a way to pool capital and access professional management while maintaining OZ tax benefits.
				</p>
			</div>
			
			<div class="oz-services-grid">
				<div class="oz-service-card">
					<div class="icon">🏗️</div>
					<h3>QOF Formation</h3>
					<p>Complete setup and structuring of your Qualified Opportunity Fund from initial formation through IRS certification.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Entity formation and structuring</li>
						<li>Operating agreement development</li>
						<li>IRS certification application</li>
						<li>Regulatory compliance setup</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">📋</div>
					<h3>Compliance Management</h3>
					<p>Ongoing compliance monitoring to ensure your QOF meets all IRS requirements and maintains tax benefits.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>90% asset test compliance</li>
						<li>Substantial improvement requirements</li>
						<li>Annual reporting and documentation</li>
						<li>IRS audit support</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">💰</div>
					<h3>Fund Administration</h3>
					<p>Comprehensive fund administration services including investor relations, reporting, and operational support.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Investor onboarding and KYC</li>
						<li>Capital call management</li>
						<li>Distribution processing</li>
						<li>Financial reporting</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">📊</div>
					<h3>Performance Monitoring</h3>
					<p>Regular monitoring and reporting on fund performance, compliance status, and investment opportunities.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Performance tracking and reporting</li>
						<li>Compliance monitoring</li>
						<li>Risk assessment and management</li>
						<li>Investor communication</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- QOF Requirements -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>QOF Requirements & Compliance</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">📋 Formation Requirements</h3>
					<ul style="text-align: left;">
						<li>Organized as corporation or partnership</li>
						<li>At least 90% of assets in OZ property</li>
						<li>Self-certification with IRS</li>
						<li>Proper documentation and record-keeping</li>
					</ul>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">⏰ Timing Requirements</h3>
					<ul style="text-align: left;">
						<li>180-day investment window</li>
						<li>Substantial improvement within 30 months</li>
						<li>Continuous compliance monitoring</li>
						<li>Annual reporting requirements</li>
					</ul>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏗️ Asset Requirements</h3>
					<ul style="text-align: left;">
						<li>90% of assets in OZ property</li>
						<li>Substantial improvement requirements</li>
						<li>Original use or substantial improvement</li>
						<li>Active business operations</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- QOF vs Direct Investment -->
	<section class="oz-tools">
		<div class="oz-tools-content">
			<h2>QOF vs. Direct Investment Comparison</h2>
			<div style="max-width: 1000px; margin: 0 auto;">
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 2rem; margin-top: 3rem;">
					<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
						<h3 style="color: var(--oz-navy); margin-bottom: 1.5rem; text-align: center;">🏛️ Qualified Opportunity Fund</h3>
						<div style="margin-bottom: 1.5rem;">
							<h4 style="color: var(--oz-gold); margin-bottom: 0.5rem;">Advantages:</h4>
							<ul style="text-align: left;">
								<li>Professional management and expertise</li>
								<li>Diversification across multiple properties</li>
								<li>Lower minimum investment requirements</li>
								<li>Reduced operational responsibilities</li>
								<li>Access to institutional-quality deals</li>
								<li>Built-in compliance monitoring</li>
							</ul>
						</div>
						<div>
							<h4 style="color: var(--oz-error); margin-bottom: 0.5rem;">Considerations:</h4>
							<ul style="text-align: left;">
								<li>Management fees (typically 1-2%)</li>
								<li>Carried interest (typically 15-20%)</li>
								<li>Less control over investment decisions</li>
								<li>Limited liquidity options</li>
							</ul>
						</div>
					</div>
					
					<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
						<h3 style="color: var(--oz-navy); margin-bottom: 1.5rem; text-align: center;">🏢 Direct Investment</h3>
						<div style="margin-bottom: 1.5rem;">
							<h4 style="color: var(--oz-gold); margin-bottom: 0.5rem;">Advantages:</h4>
							<ul style="text-align: left;">
								<li>Full control over investment decisions</li>
								<li>No management fees or carried interest</li>
								<li>Direct ownership of property</li>
								<li>Potential for higher returns</li>
								<li>Flexibility in operations</li>
								<li>Direct tax benefits</li>
							</ul>
						</div>
						<div>
							<h4 style="color: var(--oz-error); margin-bottom: 0.5rem;">Considerations:</h4>
							<ul style="text-align: left;">
								<li>Requires significant expertise and time</li>
								<li>Higher minimum investment requirements</li>
								<li>Single property risk</li>
								<li>Compliance responsibility</li>
								<li>Operational management required</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- QOF Formation Process -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>QOF Formation Process</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">1</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Entity Formation</h3>
					<p>Form the legal entity (corporation or partnership) and establish the organizational structure with proper governance.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">2</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Documentation</h3>
					<p>Develop operating agreements, subscription documents, and all necessary legal documentation for the fund.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">3</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">IRS Certification</h3>
					<p>Submit self-certification to the IRS and ensure all requirements are met for QOF status.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">4</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Operations Setup</h3>
					<p>Establish operational systems, compliance monitoring, and investor relations processes.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Case Study -->
	<section class="oz-testimonials">
		<div class="oz-testimonials-content">
			<h2>QOF Formation Success Story</h2>
			<div style="max-width: 800px; margin: 0 auto;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1.5rem;">Multi-Family Development QOF</h3>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Challenge:</strong> Real estate developer wanted to raise $25M for multi-family development projects across three Opportunity Zones.
					</p>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Solution:</strong> We formed a Qualified Opportunity Fund with the following structure:
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>Delaware LLC structure for tax efficiency</li>
						<li>Professional management team with 15+ years experience</li>
						<li>Diversified portfolio across Austin, Denver, and Miami</li>
						<li>2% management fee, 15% carried interest</li>
						<li>Minimum investment: $250K</li>
					</ul>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Results:</strong>
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>Successfully raised $25M from 45 accredited investors</li>
						<li>Acquired 3 development sites within 6 months</li>
						<li>Projected 15% IRR over 7-year hold period</li>
						<li>Full compliance with all QOF requirements</li>
						<li>Investors benefit from professional management and diversification</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Ready to Form Your QOF?</h2>
			<p>Get expert guidance on Qualified Opportunity Fund formation, compliance, and management to maximize your investment potential.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Start QOF Formation</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download QOF Guide</a>
			</div>
		</div>
	</section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Qualified Opportunity Fund Formation & Management",
  "description": "Expert guidance for QOF formation, compliance, and ongoing administration",
  "provider": {
    "@type": "Organization",
    "name": "OZ Specialist",
    "url": "https://opportunityzonespecialist.com"
  },
  "serviceType": "Fund Formation",
  "areaServed": "United States",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "QOF Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "QOF Formation"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Compliance Management"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Fund Administration"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Performance Monitoring"
        }
      }
    ]
  }
}
</script>

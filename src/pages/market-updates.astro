---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>OZ Market Updates</h1>
			<p class="subtitle">Latest insights on Opportunity Zone markets, regulations, and investment opportunities</p>
		</div>
	</section>

	<!-- Latest Updates -->
	<section class="oz-services">
		<div class="oz-services-content">
			<div style="max-width: 800px; margin: 0 auto; text-align: center;">
				<h2>Latest Market Insights</h2>
				<p style="font-size: 1.125rem; color: var(--oz-gray-600); margin-bottom: 3rem;">
					Stay informed with our monthly Opportunity Zone market reports, regulatory updates, and investment opportunity alerts.
				</p>
			</div>
			
			<!-- Featured Update -->
			<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow-lg); margin-bottom: 3rem; border-left: 4px solid var(--oz-gold);">
				<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
					<span style="background: var(--oz-gold); color: var(--oz-white); padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; font-weight: 600;">FEATURED</span>
					<span style="color: var(--oz-gray-500); font-size: 0.875rem;">December 2024</span>
				</div>
				<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Q4 2024 Opportunity Zone Market Report</h3>
				<p style="color: var(--oz-gray-600); margin-bottom: 1.5rem;">
					Our comprehensive analysis of Opportunity Zone markets across the United States, including investment trends, regulatory updates, and emerging opportunities in key markets.
				</p>
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<h4 style="color: var(--oz-navy); margin: 0 0 0.5rem 0; font-size: 1rem;">Total OZ Investment</h4>
						<p style="margin: 0; font-size: 1.5rem; font-weight: 700; color: var(--oz-gold);">$75.2B</p>
					</div>
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<h4 style="color: var(--oz-navy); margin: 0 0 0.5rem 0; font-size: 1rem;">Active QOFs</h4>
						<p style="margin: 0; font-size: 1.5rem; font-weight: 700; color: var(--oz-gold);">1,247</p>
					</div>
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<h4 style="color: var(--oz-navy); margin: 0 0 0.5rem 0; font-size: 1rem;">Properties Developed</h4>
						<p style="margin: 0; font-size: 1.5rem; font-weight: 700; color: var(--oz-gold);">8,934</p>
					</div>
				</div>
				<a href="#" class="oz-btn oz-btn-primary">Read Full Report</a>
			</div>
			
			<!-- Market Updates Grid -->
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
						<span style="background: var(--oz-navy); color: var(--oz-white); padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; font-weight: 600;">REGULATORY</span>
						<span style="color: var(--oz-gray-500); font-size: 0.875rem;">November 2024</span>
					</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">IRS Issues New OZ Guidance</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1.5rem;">
						The IRS has released new guidance on Opportunity Zone investments, clarifying compliance requirements and providing additional flexibility for certain transactions.
					</p>
					<a href="#" class="oz-btn oz-btn-outline">Read More</a>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
						<span style="background: var(--oz-success); color: var(--oz-white); padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; font-weight: 600;">MARKET</span>
						<span style="color: var(--oz-gray-500); font-size: 0.875rem;">November 2024</span>
					</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Austin OZ Market Surges</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1.5rem;">
						Austin's Opportunity Zone markets are experiencing unprecedented growth, with new developments and strong investor interest driving property values higher.
					</p>
					<a href="#" class="oz-btn oz-btn-outline">Read More</a>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
						<span style="background: var(--oz-info); color: var(--oz-white); padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; font-weight: 600;">OPPORTUNITY</span>
						<span style="color: var(--oz-gray-500); font-size: 0.875rem;">October 2024</span>
					</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Denver Mixed-Use Development</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1.5rem;">
						A new $50M mixed-use development opportunity in Denver's Opportunity Zone, featuring residential, retail, and office components with strong projected returns.
					</p>
					<a href="#" class="oz-btn oz-btn-outline">Read More</a>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
						<span style="background: var(--oz-warning); color: var(--oz-white); padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; font-weight: 600;">ALERT</span>
						<span style="color: var(--oz-gray-500); font-size: 0.875rem;">October 2024</span>
					</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Deadline Reminder: 2024 Investments</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1.5rem;">
						Important reminder for investors considering Opportunity Zone investments in 2024. Key deadlines and timing considerations for maximizing tax benefits.
					</p>
					<a href="#" class="oz-btn oz-btn-outline">Read More</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Market Trends -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Key Market Trends</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏙️ Urban Development Focus</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Investors are increasingly focusing on urban Opportunity Zones, particularly in growing metropolitan areas with strong job markets and infrastructure development.
					</p>
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<p style="margin: 0; font-size: 0.875rem; color: var(--oz-gray-600);"><strong>Top Markets:</strong> Austin, Denver, Miami, Nashville</p>
					</div>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏠 Multi-Family Dominance</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Multi-family residential developments continue to dominate Opportunity Zone investments, driven by strong rental demand and favorable financing conditions.
					</p>
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<p style="margin: 0; font-size: 0.875rem; color: var(--oz-gray-600);"><strong>Market Share:</strong> 45% of all OZ investments</p>
					</div>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">💰 Institutional Interest</h3>
					<p style="color: var(--oz-gray-600); margin-bottom: 1rem;">
						Large institutional investors are increasingly entering the Opportunity Zone market, bringing significant capital and professional management expertise.
					</p>
					<div style="background: var(--oz-gray-50); padding: 1rem; border-radius: 0.375rem;">
						<p style="margin: 0; font-size: 0.875rem; color: var(--oz-gray-600);"><strong>Growth:</strong> 35% increase in institutional capital</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Newsletter Signup -->
	<section class="oz-tools">
		<div class="oz-tools-content">
			<div style="max-width: 600px; margin: 0 auto; text-align: center;">
				<h2>Get Market Updates Delivered</h2>
				<p style="color: var(--oz-gray-600); margin-bottom: 2rem;">
					Subscribe to our monthly Opportunity Zone market reports and receive the latest insights directly in your inbox.
				</p>
				
				<form class="oz-form" id="market-newsletter-form" style="max-width: 500px; margin: 0 auto;">
					<div class="oz-form-group">
						<label class="oz-form-label" for="market-email">Email Address</label>
						<input type="email" id="market-email" name="email" class="oz-form-input" required>
					</div>
					<div class="oz-form-group">
						<label class="oz-form-label" for="market-name">Full Name</label>
						<input type="text" id="market-name" name="name" class="oz-form-input" required>
					</div>
					<button type="submit" class="oz-btn oz-btn-primary" style="width: 100%;">Subscribe to Updates</button>
				</form>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Ready to Capitalize on Market Opportunities?</h2>
			<p>Don't miss out on the latest Opportunity Zone investment opportunities. Schedule a consultation with our specialists to discuss current market conditions and investment strategies.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Schedule Consultation</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download Market Guide</a>
			</div>
		</div>
	</section>
</Layout>

<script>
	// Market newsletter signup
	document.getElementById('market-newsletter-form').addEventListener('submit', function(e) {
		e.preventDefault();
		
		const email = document.getElementById('market-email').value;
		const name = document.getElementById('market-name').value;
		
		// In a real implementation, this would send data to your email service
		console.log('Market newsletter signup:', { email, name });
		
		alert('Thank you for subscribing! You\'ll receive our monthly OZ market updates and insights.');
		
		// Reset form
		this.reset();
	});
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "OZ Market Updates",
  "description": "Latest insights on Opportunity Zone markets, regulations, and investment opportunities",
  "url": "https://opportunityzonespecialist.com/market-updates",
  "publisher": {
    "@type": "Organization",
    "name": "OZ Specialist",
    "url": "https://opportunityzonespecialist.com"
  },
  "blogPost": [
    {
      "@type": "BlogPosting",
      "headline": "Q4 2024 Opportunity Zone Market Report",
      "description": "Comprehensive analysis of Opportunity Zone markets across the United States",
      "datePublished": "2024-12-01",
      "author": {
        "@type": "Organization",
        "name": "OZ Specialist"
      }
    },
    {
      "@type": "BlogPosting",
      "headline": "IRS Issues New OZ Guidance",
      "description": "New guidance on Opportunity Zone investments and compliance requirements",
      "datePublished": "2024-11-15",
      "author": {
        "@type": "Organization",
        "name": "OZ Specialist"
      }
    }
  ]
}
</script>

---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>Opportunity Zone Property Analysis</h1>
			<p class="subtitle">Expert evaluation and due diligence for OZ-eligible properties and developments</p>
		</div>
	</section>

	<!-- Service Overview -->
	<section class="oz-services">
		<div class="oz-services-content">
			<div style="max-width: 800px; margin: 0 auto; text-align: center;">
				<h2>Comprehensive Property Evaluation & Due Diligence</h2>
				<p style="font-size: 1.125rem; color: var(--oz-gray-600); margin-bottom: 3rem;">
					Our property analysis services provide in-depth evaluation of Opportunity Zone properties, ensuring you make informed investment decisions with confidence. We assess market conditions, development potential, and compliance requirements.
				</p>
			</div>
			
			<div class="oz-services-grid">
				<div class="oz-service-card">
					<div class="icon">📍</div>
					<h3>OZ Eligibility Verification</h3>
					<p>Confirm that properties are located within designated Opportunity Zones and meet all IRS requirements for OZ investment.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Zone boundary verification</li>
						<li>Property address validation</li>
						<li>IRS designation confirmation</li>
						<li>Compliance documentation</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">📊</div>
					<h3>Market Analysis</h3>
					<p>Comprehensive market research to assess property values, rental rates, and growth potential in the target area.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Comparable property analysis</li>
						<li>Market trend evaluation</li>
						<li>Rental rate assessment</li>
						<li>Growth projection modeling</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">🏗️</div>
					<h3>Development Feasibility</h3>
					<p>Evaluate the feasibility of development projects, including zoning, permits, construction costs, and timeline estimates.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Zoning compliance review</li>
						<li>Permit requirement analysis</li>
						<li>Construction cost estimation</li>
						<li>Development timeline planning</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">💰</div>
					<h3>Financial Modeling</h3>
					<p>Detailed financial analysis including cash flow projections, ROI calculations, and sensitivity analysis for various scenarios.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Cash flow projections</li>
						<li>ROI and IRR calculations</li>
						<li>Sensitivity analysis</li>
						<li>Tax benefit modeling</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Analysis Process -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Our Property Analysis Process</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">1</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Initial Assessment</h3>
					<p>We begin with a comprehensive review of the property, including location, size, condition, and current use to understand the investment opportunity.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">2</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Due Diligence</h3>
					<p>Conduct thorough due diligence including title review, environmental assessment, zoning verification, and compliance requirements.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">3</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Market Analysis</h3>
					<p>Analyze local market conditions, comparable properties, rental rates, and growth trends to assess investment potential.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">4</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Report & Recommendations</h3>
					<p>Provide a comprehensive analysis report with detailed findings, financial projections, and investment recommendations.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Property Types -->
	<section class="oz-tools">
		<div class="oz-tools-content">
			<h2>Property Types We Analyze</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏢 Commercial Real Estate</h3>
					<ul style="text-align: left;">
						<li>Office buildings</li>
						<li>Retail centers</li>
						<li>Industrial properties</li>
						<li>Mixed-use developments</li>
					</ul>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏠 Residential Properties</h3>
					<ul style="text-align: left;">
						<li>Multi-family apartments</li>
						<li>Single-family homes</li>
						<li>Condominium developments</li>
						<li>Student housing</li>
					</ul>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏭 Industrial & Manufacturing</h3>
					<ul style="text-align: left;">
						<li>Warehouses</li>
						<li>Manufacturing facilities</li>
						<li>Distribution centers</li>
						<li>Data centers</li>
					</ul>
				</div>
				
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">🏥 Special Purpose</h3>
					<ul style="text-align: left;">
						<li>Healthcare facilities</li>
						<li>Educational buildings</li>
						<li>Hospitality properties</li>
						<li>Recreational facilities</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Case Study -->
	<section class="oz-testimonials">
		<div class="oz-testimonials-content">
			<h2>Property Analysis Success Story</h2>
			<div style="max-width: 800px; margin: 0 auto;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1.5rem;">Downtown Austin Mixed-Use Development</h3>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Property:</strong> 2.5-acre site in downtown Austin Opportunity Zone
					</p>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Analysis Findings:</strong>
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>Prime location with 15% annual population growth</li>
						<li>Zoning allows for 200-unit mixed-use development</li>
						<li>Construction costs estimated at $45M</li>
						<li>Projected rental rates: $3.50/sq ft for retail, $2.25/sq ft for office</li>
						<li>Strong demand from tech companies and young professionals</li>
					</ul>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Investment Recommendation:</strong> Proceed with development
					</p>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Projected Returns:</strong>
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>IRR: 18.5% over 10 years</li>
						<li>Cash-on-cash return: 12% annually</li>
						<li>Tax benefits: $2.1M in deferred capital gains</li>
						<li>Tax-free appreciation: $8.5M projected</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Need Property Analysis for Your OZ Investment?</h2>
			<p>Get expert evaluation of Opportunity Zone properties to make informed investment decisions and maximize your returns.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Request Property Analysis</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download Analysis Checklist</a>
			</div>
		</div>
	</section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Opportunity Zone Property Analysis",
  "description": "Expert evaluation and due diligence for OZ-eligible properties and developments",
  "provider": {
    "@type": "Organization",
    "name": "OZ Specialist",
    "url": "https://opportunityzonespecialist.com"
  },
  "serviceType": "Property Analysis",
  "areaServed": "United States",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Property Analysis Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "OZ Eligibility Verification"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Market Analysis"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Development Feasibility"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Financial Modeling"
        }
      }
    ]
  }
}
</script>

---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>Opportunity Zone Investment Consulting</h1>
			<p class="subtitle">Strategic guidance for maximizing your OZ investment returns and tax benefits</p>
		</div>
	</section>

	<!-- Service Overview -->
	<section class="oz-services">
		<div class="oz-services-content">
			<div style="max-width: 800px; margin: 0 auto; text-align: center;">
				<h2>Comprehensive OZ Investment Strategy Development</h2>
				<p style="font-size: 1.125rem; color: var(--oz-gray-600); margin-bottom: 3rem;">
					Our investment consulting services help you navigate the complex world of Opportunity Zone investments with confidence. We develop tailored strategies that align with your financial goals, risk tolerance, and timeline.
				</p>
			</div>
			
			<div class="oz-services-grid">
				<div class="oz-service-card">
					<div class="icon">🎯</div>
					<h3>Investment Strategy Development</h3>
					<p>Create a comprehensive OZ investment strategy tailored to your specific financial situation, goals, and risk tolerance.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Portfolio allocation analysis</li>
						<li>Risk assessment and mitigation</li>
						<li>Timeline optimization</li>
						<li>Tax benefit maximization</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">📈</div>
					<h3>Market Analysis & Research</h3>
					<p>In-depth analysis of OZ markets, property types, and investment opportunities to identify the best potential returns.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Market trend analysis</li>
						<li>Property type evaluation</li>
						<li>Geographic opportunity assessment</li>
						<li>Competitive landscape review</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">🏛️</div>
					<h3>Fund Selection & Due Diligence</h3>
					<p>Expert evaluation of Qualified Opportunity Funds to ensure they meet your investment criteria and compliance requirements.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Fund performance analysis</li>
						<li>Management team evaluation</li>
						<li>Compliance verification</li>
						<li>Fee structure optimization</li>
					</ul>
				</div>
				
				<div class="oz-service-card">
					<div class="icon">⚖️</div>
					<h3>Risk Management</h3>
					<p>Comprehensive risk assessment and mitigation strategies to protect your investment and maximize returns.</p>
					<ul style="text-align: left; margin-top: 1rem;">
						<li>Risk identification and analysis</li>
						<li>Diversification strategies</li>
						<li>Exit strategy planning</li>
						<li>Insurance and protection</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Process Section -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Our Investment Consulting Process</h2>
			<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 3rem;">
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">1</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Initial Assessment</h3>
					<p>We begin with a comprehensive review of your financial situation, investment goals, and risk tolerance to understand your unique needs.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">2</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Strategy Development</h3>
					<p>Based on your assessment, we develop a customized OZ investment strategy that aligns with your objectives and timeline.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">3</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Implementation</h3>
					<p>We guide you through the implementation process, helping you select the right investments and ensuring proper documentation.</p>
				</div>
				
				<div style="text-align: center;">
					<div style="width: 4rem; height: 4rem; background: var(--oz-gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: var(--oz-white); font-size: 1.5rem; font-weight: 700;">4</div>
					<h3 style="color: var(--oz-navy); margin-bottom: 1rem;">Ongoing Support</h3>
					<p>We provide continuous monitoring and support throughout your investment lifecycle, ensuring compliance and optimization.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Case Study -->
	<section class="oz-testimonials">
		<div class="oz-testimonials-content">
			<h2>Investment Consulting Success Story</h2>
			<div style="max-width: 800px; margin: 0 auto;">
				<div style="background: var(--oz-white); padding: 2rem; border-radius: 0.5rem; box-shadow: var(--oz-shadow);">
					<h3 style="color: var(--oz-navy); margin-bottom: 1.5rem;">$3M OZ Investment Strategy</h3>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Challenge:</strong> A high-net-worth investor had $3M in capital gains from a business sale and wanted to defer taxes while generating strong returns.
					</p>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Solution:</strong> We developed a diversified OZ strategy including:
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>$1.5M in a multi-family development fund in Austin, TX</li>
						<li>$1M in a commercial real estate fund in Denver, CO</li>
						<li>$500K in a direct investment in a mixed-use development in Miami, FL</li>
					</ul>
					<p style="margin-bottom: 1.5rem; font-size: 1.125rem;">
						<strong>Results:</strong> 
					</p>
					<ul style="margin-bottom: 1.5rem; padding-left: 2rem;">
						<li>Deferred $600K in capital gains taxes</li>
						<li>Projected 12% annual returns over 10 years</li>
						<li>Tax-free appreciation on 15% basis step-up</li>
						<li>Total projected tax savings: $1.2M over 10 years</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Ready to Develop Your OZ Investment Strategy?</h2>
			<p>Schedule a consultation with our investment specialists to discuss your goals and explore how Opportunity Zone investments can benefit your portfolio.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Schedule Consultation</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download Investment Guide</a>
			</div>
		</div>
	</section>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Opportunity Zone Investment Consulting",
  "description": "Strategic guidance for maximizing your OZ investment returns and tax benefits",
  "provider": {
    "@type": "Organization",
    "name": "OZ Specialist",
    "url": "https://opportunityzonespecialist.com"
  },
  "serviceType": "Investment Consulting",
  "areaServed": "United States",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "OZ Investment Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Investment Strategy Development"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Market Analysis & Research"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Fund Selection & Due Diligence"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Risk Management"
        }
      }
    ]
  }
}
</script>

---
import Layout from '../layouts/Page.astro';
import '../styles/oz-custom.css';
---

<Layout>
	<!-- Hero Section -->
	<section class="oz-hero">
		<div class="oz-hero-content">
			<h1>Opportunity Zone Investment Specialist</h1>
			<p class="subtitle">Maximize Tax Benefits • Identify Prime Properties • Ensure Compliance</p>
			<div class="oz-hero-cta">
				<form class="oz-form" id="hero-lead-form">
					<h3>Get Your Free OZ Investment Analysis</h3>
					<div class="oz-form-group">
						<label class="oz-form-label" for="name">Full Name</label>
						<input type="text" id="name" name="name" class="oz-form-input" required>
					</div>
					<div class="oz-form-group">
						<label class="oz-form-label" for="email">Email Address</label>
						<input type="email" id="email" name="email" class="oz-form-input" required>
					</div>
					<div class="oz-form-group">
						<label class="oz-form-label" for="investment-amount">Investment Amount</label>
						<select id="investment-amount" name="investment-amount" class="oz-form-input" required>
							<option value="">Select Range</option>
							<option value="100k-500k">$100K - $500K</option>
							<option value="500k-1m">$500K - $1M</option>
							<option value="1m-5m">$1M - $5M</option>
							<option value="5m+">$5M+</option>
						</select>
					</div>
					<button type="submit" class="oz-btn oz-btn-primary" style="width: 100%;">Get Free Analysis</button>
				</form>
			</div>
		</div>
	</section>

	<!-- Authority Positioning Section -->
	<section class="oz-authority">
		<div class="oz-authority-content">
			<h2>Why Choose an OZ Specialist vs. General Advisors</h2>
			<div class="oz-authority-grid">
				<div class="oz-authority-card">
					<h3>Deep OZ Expertise</h3>
					<p>Unlike general financial advisors, we specialize exclusively in Opportunity Zone investments, staying current with the latest regulations and market opportunities.</p>
				</div>
				<div class="oz-authority-card">
					<h3>Proven Track Record</h3>
					<p>We've analyzed over $2.5 billion in OZ transactions and helped clients achieve average tax savings of 15-25% on their capital gains.</p>
				</div>
				<div class="oz-authority-card">
					<h3>Compliance Assurance</h3>
					<p>Our team ensures every investment meets IRS requirements, protecting your tax benefits and avoiding costly compliance issues.</p>
				</div>
			</div>
			<div class="oz-authority-stats">
				<div class="oz-stat">
					<span class="oz-stat-number">$2.5B+</span>
					<span class="oz-stat-label">OZ Transactions Analyzed</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">500+</span>
					<span class="oz-stat-label">Properties Evaluated</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">15+</span>
					<span class="oz-stat-label">Years Experience</span>
				</div>
				<div class="oz-stat">
					<span class="oz-stat-number">98%</span>
					<span class="oz-stat-label">Client Satisfaction</span>
				</div>
			</div>
		</div>
	</section>

	<!-- Services Overview Section -->
	<section class="oz-services">
		<div class="oz-services-content">
			<h2>Our OZ Investment Services</h2>
			<div class="oz-services-grid">
				<div class="oz-service-card">
					<div class="icon">📊</div>
					<h3>Investment Strategy Consulting</h3>
					<p>Develop comprehensive OZ investment strategies tailored to your financial goals, risk tolerance, and timeline. We analyze market conditions and identify optimal investment opportunities.</p>
					<a href="/investment-consulting" class="oz-btn oz-btn-outline">Learn More</a>
				</div>
				<div class="oz-service-card">
					<div class="icon">🏢</div>
					<h3>Property Identification & Analysis</h3>
					<p>Our team identifies and evaluates OZ-eligible properties, conducting thorough due diligence on market conditions, development potential, and compliance requirements.</p>
					<a href="/property-analysis" class="oz-btn oz-btn-outline">Learn More</a>
				</div>
				<div class="oz-service-card">
					<div class="icon">💰</div>
					<h3>Tax Optimization</h3>
					<p>Maximize your tax benefits through strategic planning, including capital gains deferral, basis step-up strategies, and long-term tax-free appreciation planning.</p>
					<a href="/tax-benefits" class="oz-btn oz-btn-outline">Learn More</a>
				</div>
				<div class="oz-service-card">
					<div class="icon">🏛️</div>
					<h3>QOF Formation & Management</h3>
					<p>Assist with Qualified Opportunity Fund formation, compliance management, and ongoing fund administration to ensure IRS requirements are met throughout the investment lifecycle.</p>
					<a href="/qualified-opportunity-funds" class="oz-btn oz-btn-outline">Learn More</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Interactive Tools Section -->
	<section class="oz-tools">
		<div class="oz-tools-content">
			<h2>OZ Investment Tools & Resources</h2>
			<div class="oz-tools-grid">
				<div class="oz-tool-card">
					<h3>OZ Zone Lookup Tool</h3>
					<p>Quickly verify if any property is located within a designated Opportunity Zone using our integrated Treasury Department mapping tool.</p>
					<iframe 
						src="https://www.cdfifund.gov/nmtc-public-viewer" 
						title="OZ Property Lookup Tool"
						width="100%" 
						height="400"
						style="border: 1px solid #e5e7eb; border-radius: 0.375rem; margin-top: 1rem;">
					</iframe>
				</div>
				<div class="oz-tool-card">
					<h3>ROI Calculator</h3>
					<p>Calculate potential returns and tax savings for your Opportunity Zone investment with our comprehensive ROI calculator.</p>
					<div id="roi-calculator" style="margin-top: 1rem;">
						<div class="oz-form-group">
							<label class="oz-form-label">Investment Amount</label>
							<input type="number" id="investment-amount-calc" class="oz-form-input" placeholder="$1,000,000">
						</div>
						<div class="oz-form-group">
							<label class="oz-form-label">Capital Gains Rate</label>
							<input type="number" id="cap-gains-rate" class="oz-form-input" placeholder="20" value="20">
						</div>
						<div class="oz-form-group">
							<label class="oz-form-label">Hold Period (Years)</label>
							<input type="number" id="hold-period" class="oz-form-input" placeholder="10" value="10">
						</div>
						<button onclick="calculateROI()" class="oz-btn oz-btn-primary" style="width: 100%;">Calculate ROI</button>
						<div id="roi-results" style="margin-top: 1rem; padding: 1rem; background: #f9fafb; border-radius: 0.375rem; display: none;">
							<h4>Projected Results:</h4>
							<p id="tax-savings"></p>
							<p id="net-returns"></p>
						</div>
					</div>
				</div>
				<div class="oz-tool-card">
					<h3>Compliance Deadline Tracker</h3>
					<p>Track important deadlines and requirements for your Opportunity Zone investment to ensure compliance and maximize benefits.</p>
					<div id="deadline-tracker" style="margin-top: 1rem;">
						<div class="oz-form-group">
							<label class="oz-form-label">Investment Date</label>
							<input type="date" id="investment-date" class="oz-form-input">
						</div>
						<div class="oz-form-group">
							<label class="oz-form-label">Fund Type</label>
							<select id="fund-type" class="oz-form-input">
								<option value="qof">Qualified Opportunity Fund</option>
								<option value="direct">Direct Investment</option>
							</select>
						</div>
						<button onclick="trackDeadlines()" class="oz-btn oz-btn-primary" style="width: 100%;">Track Deadlines</button>
						<div id="deadline-results" style="margin-top: 1rem; padding: 1rem; background: #f9fafb; border-radius: 0.375rem; display: none;">
							<h4>Key Deadlines:</h4>
							<div id="deadline-list"></div>
						</div>
					</div>
				</div>
			</div>
			</div>
		</section>

	<!-- Client Success Stories -->
	<section class="oz-testimonials">
		<div class="oz-testimonials-content">
			<h2>Client Success Stories</h2>
			<div class="oz-testimonials-grid">
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">OZ Specialist helped us structure a $5M investment that resulted in $1.2M in tax savings over 10 years. Their expertise in compliance and property analysis was invaluable.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">JS</div>
						<div class="oz-testimonial-info">
							<h4>John Smith</h4>
							<p>Real Estate Developer, Miami</p>
						</div>
					</div>
				</div>
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">We were skeptical about Opportunity Zones until we worked with OZ Specialist. They identified a property that appreciated 40% in 3 years while providing significant tax benefits.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">MJ</div>
						<div class="oz-testimonial-info">
							<h4>Maria Johnson</h4>
							<p>Investment Advisor, Austin</p>
						</div>
					</div>
				</div>
				<div class="oz-testimonial">
					<p class="oz-testimonial-text">The team's knowledge of OZ regulations saved us from a costly compliance mistake. Their ongoing support throughout the investment lifecycle has been exceptional.</p>
					<div class="oz-testimonial-author">
						<div class="oz-testimonial-avatar">RB</div>
						<div class="oz-testimonial-info">
							<h4>Robert Brown</h4>
							<p>High Net Worth Investor, Denver</p>
						</div>
					</div>
				</div>
			</div>
			</div>
		</section>

	<!-- CTA Section -->
	<section class="oz-cta">
		<div class="oz-cta-content">
			<h2>Ready to Maximize Your OZ Investment Potential?</h2>
			<p>Schedule a free consultation with our Opportunity Zone specialists to discuss your investment goals and explore tax-saving opportunities.</p>
			<div class="oz-hero .cta-buttons">
				<a href="/contact" class="oz-btn oz-btn-primary">Schedule Free Consultation</a>
				<a href="/resources/guides" class="oz-btn oz-btn-secondary">Download OZ Guide</a>
			</div>
			</div>
		</section>
</Layout>

<script>
	// ROI Calculator
	function calculateROI() {
		const investment = parseFloat((document.getElementById('investment-amount-calc') as HTMLInputElement)?.value || '0');
		const capGainsRate = parseFloat((document.getElementById('cap-gains-rate') as HTMLInputElement)?.value || '0') / 100;
		const holdPeriod = parseInt((document.getElementById('hold-period') as HTMLInputElement)?.value || '0');
		
		if (!investment || !capGainsRate || !holdPeriod) {
			alert('Please fill in all fields');
			return;
		}
		
		// Simplified calculation - in reality, this would be more complex
		const annualReturn = 0.08; // 8% annual return assumption
		const futureValue = investment * Math.pow(1 + annualReturn, holdPeriod);
		const appreciation = futureValue - investment;
		const taxSavings = appreciation * capGainsRate;
		const netReturns = futureValue - taxSavings;
		
		document.getElementById('tax-savings').innerHTML = `Tax Savings: $${taxSavings.toLocaleString()}`;
		document.getElementById('net-returns').innerHTML = `Net Returns: $${netReturns.toLocaleString()}`;
		document.getElementById('roi-results').style.display = 'block';
	}
	
	// Deadline Tracker
	function trackDeadlines() {
		const investmentDate = new Date((document.getElementById('investment-date') as HTMLInputElement)?.value || '');
		const fundType = (document.getElementById('fund-type') as HTMLSelectElement)?.value || '';
		
		if (!investmentDate) {
			alert('Please select an investment date');
			return;
		}
		
		const deadlines = [];
		
		if (fundType === 'qof') {
			// QOF specific deadlines
			const qofDeadline = new Date(investmentDate);
			qofDeadline.setDate(qofDeadline.getDate() + 180); // 180 days to invest in QOF
			deadlines.push({
				date: qofDeadline,
				description: '180-day deadline to invest in QOF'
			});
		}
		
		// 10-year hold for full benefits
		const tenYearDate = new Date(investmentDate);
		tenYearDate.setFullYear(tenYearDate.getFullYear() + 10);
		deadlines.push({
			date: tenYearDate,
			description: '10-year hold period for tax-free appreciation'
		});
		
		// 5-year basis step-up
		const fiveYearDate = new Date(investmentDate);
		fiveYearDate.setFullYear(fiveYearDate.getFullYear() + 5);
		deadlines.push({
			date: fiveYearDate,
			description: '5-year basis step-up (10% reduction)'
		});
		
		// 7-year basis step-up
		const sevenYearDate = new Date(investmentDate);
		sevenYearDate.setFullYear(sevenYearDate.getFullYear() + 7);
		deadlines.push({
			date: sevenYearDate,
			description: '7-year basis step-up (15% reduction)'
		});
		
		let deadlineHTML = '';
		deadlines.forEach(deadline => {
			deadlineHTML += `<p><strong>${deadline.date.toLocaleDateString()}:</strong> ${deadline.description}</p>`;
		});
		
		document.getElementById('deadline-list').innerHTML = deadlineHTML;
		document.getElementById('deadline-results').style.display = 'block';
	}
	
	// Lead form submission
	document.getElementById('hero-lead-form').addEventListener('submit', function(e) {
		e.preventDefault();
		// In a real implementation, this would send data to your CRM/email service
		alert('Thank you! We\'ll contact you within 24 hours with your free OZ investment analysis.');
	});
</script>

<style>
	.oz-hero-cta {
		margin-top: 2rem;
	}
	
	.oz-hero .cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-top: 2rem;
	}
</style>

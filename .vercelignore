# Vercel ignore file for optimized builds
# Ignore development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore build artifacts
dist/
.astro/

# Ignore development dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore test files
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Ignore documentation that's not needed for build
README.md
CHANGELOG.md
LICENSE

# Ignore git files
.git/
.gitignore

# Ignore Biome cache
.biome/

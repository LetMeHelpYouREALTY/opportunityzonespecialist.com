# Git attributes for optimized Vercel deployment

# Ensure consistent line endings
* text=auto
*.js text eol=lf
*.ts text eol=lf
*.astro text eol=lf
*.mdx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Package files
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf

# Config files
*.config.js text eol=lf
*.config.mjs text eol=lf
*.config.ts text eol=lf

# Documentation
*.md text eol=lf
README.md text eol=lf
